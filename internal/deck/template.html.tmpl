<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="color-scheme" content="dark">
<title>{{ .OrgName }} — AI Impact Report</title>
<link rel="stylesheet" href="assets/reveal.css">
<style>
  :root {
    --bg: #0b0f17;
    --bg-elev: #11172a;
    --fg: #e5e7eb;
    --fg-muted: #9ca3af;
    --fg-dim: #6b7280;
    --accent: #f59e0b;
    --accent-2: #3b82f6;
    --border: #1f2937;
    --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }
  /* reveal.js adds class="reveal-viewport" to <body> at init time, so a
     bare `body { background: ... }` rule loses the specificity battle
     against reveal.css's `.reveal-viewport { background: white }`.
     Target the same class to win. The bg-fx canvas paints the actual
     background behind everything; the colour here is a fallback for when
     JS / canvas is unavailable. */
  html { background: var(--bg); }
  body, .reveal-viewport { background: var(--bg); margin: 0; }
  .reveal {
    background: transparent;
    color: var(--fg);
    font-family: var(--font-sans);
    font-size: 32px;
    font-weight: 400;
    position: relative;
    z-index: 1;
  }
  .reveal .slides { text-align: left; }
  .reveal h1, .reveal h2, .reveal h3, .reveal h4 {
    font-family: var(--font-sans);
    color: var(--fg);
    text-transform: none;
    letter-spacing: -0.01em;
    font-weight: 700;
    margin: 0 0 0.4em;
    line-height: 1.15;
  }
  .reveal h1 { font-size: 2.6em; }
  .reveal h2 { font-size: 1.6em; }
  .reveal h3 { font-size: 1.1em; color: var(--fg-muted); font-weight: 500; }
  .reveal h4 { font-size: 0.9em; margin: 0.7em 0 0.25em; }
  .reveal p { margin: 0.4em 0; line-height: 1.4; }
  .reveal a { color: var(--accent-2); }
  .reveal code {
    background: var(--bg-elev);
    padding: 1px 6px;
    border-radius: 3px;
    color: var(--accent);
    font-size: 0.85em;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
  }
  .reveal ul { line-height: 1.5; margin: 0.2em 0 0.4em; padding-left: 1.2em; }
  .reveal li + li { margin-top: 0.25em; }
  .reveal b, .reveal strong { font-weight: 600; }
  .reveal .controls { color: var(--fg-muted); }
  .reveal .progress {
    color: var(--accent);
    background: var(--border);
    height: 3px;
  }
  .reveal .slide-number {
    background: transparent;
    color: var(--fg-dim);
    font-size: 13px;
  }

  /* Generic helpers */
  .reveal .eyebrow {
    font-size: 0.65em;
    color: var(--fg-muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0;
  }
  .reveal .accent { color: var(--accent); }
  .reveal .muted { color: var(--fg-muted); }
  .reveal .footnote {
    font-size: 0.55em;
    color: var(--fg-dim);
    margin-top: 0.8em;
  }

  /* Title slide — centered hero */
  .reveal .title-slide {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    height: 100%;
    min-height: 600px;
  }
  .reveal .title-slide .eyebrow { margin-bottom: 1.2em; }
  .reveal .title-slide h1 { color: var(--accent); margin: 0; font-size: 3em; }
  .reveal .title-slide .date {
    font-size: 1em;
    color: var(--fg-muted);
    margin: 0.8em 0 0.4em;
  }
  .reveal .title-slide .footnote { margin-top: 1em; font-size: 0.5em; }

  /* Big-number grid (adoption slide) */
  .reveal .big-number-grid {
    display: flex;
    justify-content: stretch;
    gap: 18px;
    margin: 0.8em 0 0;
  }
  .reveal .big-number-grid > div {
    flex: 1;
    text-align: center;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.9em 0.7em;
  }
  .reveal .big-number {
    font-size: 2.4em;
    font-weight: 700;
    line-height: 1;
    margin: 0 0 0.2em;
    color: var(--fg);
    letter-spacing: -0.02em;
  }
  .reveal .big-number.accent { color: var(--accent); }
  .reveal .big-number-grid p:not(.big-number) {
    color: var(--fg-muted);
    font-size: 0.5em;
    line-height: 1.35;
    margin: 0;
  }

  /* Charts. Fixed pixel dimensions in reveal's logical-slide coords
     (default 960x700) — reveal scales the slide via transform, so
     percentages / vh would fight that scale and ECharts would mis-measure. */
  .reveal .chart {
    width: 880px;
    height: 440px;
    margin: 14px auto 0;
  }

  /* Stats slide — compact distribution table */
  .reveal .stats-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.6em;
    margin: 0.3em 0 0.5em;
  }
  .reveal .stats-table th,
  .reveal .stats-table td {
    padding: 0.35em 0.6em;
    text-align: right;
    border-bottom: 1px solid var(--border);
  }
  .reveal .stats-table th {
    color: var(--fg-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85em;
  }
  .reveal .stats-table th:first-child,
  .reveal .stats-table td:first-child {
    text-align: left;
    color: var(--fg-muted);
  }
  .reveal .stats-table td.accent { color: var(--accent); font-weight: 600; }
  .reveal .stats-trend {
    font-size: 0.65em;
    margin: 0.3em 0 0.8em;
    color: var(--fg-muted);
  }
  .reveal .stats-trend .accent { color: var(--accent); font-weight: 600; }
  .reveal .stats-cohort-grid {
    display: flex;
    gap: 14px;
    margin-top: 0.4em;
  }
  .reveal .stats-cohort-grid > div {
    flex: 1;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5em 0.7em;
    font-size: 0.6em;
  }
  .reveal .stats-cohort-grid h4 {
    margin: 0 0 0.2em;
    color: var(--accent);
    font-size: 0.95em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  .reveal .stats-cohort-grid p { margin: 0.15em 0; }
  .reveal .stats-tools {
    margin-top: 0.6em;
  }
  .reveal .stats-tools h4 {
    margin: 0 0 0.15em;
    color: var(--accent);
    font-size: 0.6em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  .reveal .stats-tools-table {
    width: auto;
    min-width: 360px;
    font-size: 0.55em;
  }
  .reveal .stats-tools-table th:first-child,
  .reveal .stats-tools-table td:first-child {
    color: var(--fg);
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
  }

  /* Methodology / caveats — denser body type */
  .reveal .caveats {
    font-size: 0.7em;
    line-height: 1.55;
    color: var(--fg);
  }
  .reveal .caveats h4 {
    color: var(--accent);
    font-size: 0.85em;
    margin: 0.4em 0 0.2em;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }
  .reveal .caveats ul { margin: 0.2em 0 0.6em; }
  .reveal .caveats p { margin: 0.4em 0; }

  /* Background — full-viewport canvas behind the slides renders a
     3-layer parallax starfield in gray. The slide stack sits at
     z-index: 1 above it; nothing else needs to be aware of the canvas. */
  #bg-fx {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    display: block;
  }

  /* Brand logo — fixed to the viewport so it rides above every slide.
     Sits outside .reveal so it isn't affected by reveal's slide-scale transform. */
  .deck-logo {
    position: fixed;
    top: 18px;
    right: 22px;
    height: 44px;
    width: auto;
    opacity: 0.85;
    z-index: 1000;
    pointer-events: none;
    user-select: none;
  }
</style>
</head>
<body>
<canvas id="bg-fx" aria-hidden="true"></canvas>
<img class="deck-logo" src="assets/loupe.svg" alt="Loupe">
<div class="reveal">
<div class="slides">

<section>
  <div class="title-slide">
    <p class="eyebrow">AI Impact Report</p>
    <h1>{{ .OrgName }}</h1>
    <p class="date">Week of {{ .ReportDate.Format "January 2, 2006" }}</p>
    <p class="footnote">Window: {{ .WindowStart.Format "Jan 02, 2006" }} – {{ .WindowEnd.Format "Jan 02, 2006" }}</p>
  </div>
  <aside class="notes">
    Loupe baseline report. Local-only — no data left this machine. Skeptic mode: the methodology slide lists what we measured and how.
  </aside>
</section>

<section>
  <h2>Adoption</h2>
  <div class="big-number-grid">
    <div>
      <p class="big-number">{{ .TotalCommits }}</p>
      <p>commits over {{ len .Weeks }} weeks</p>
    </div>
    <div>
      <p class="big-number accent">{{ printf "%.1f%%" .AICommitPct }}</p>
      <p>of commits carry an AI co-author trailer</p>
    </div>
    <div>
      <p class="big-number">{{ .AIAuthorCount }}/{{ .DistinctAuthorCount }}</p>
      <p>devs with at least one AI-tagged commit</p>
    </div>
  </div>
  <p class="footnote">{{ .CutoverText }}</p>
  <aside class="notes">
    Trailer-based detection is conservative: Claude and Aider write Co-Authored-By trailers by default; Cursor and Copilot generally don't. Real adoption among Cursor/Copilot users is likely higher.
  </aside>
</section>

<section data-chart="throughput">
  <h2>Weekly throughput</h2>
  <div id="throughput-chart" class="chart"></div>
  <aside class="notes">
    Commits per week, stacked human vs AI-tagged. Merge commits included. A truncated rightmost bar usually reflects a partial week.
  </aside>
</section>

<section data-chart="adoption">
  <h2>Adoption over time</h2>
  <div id="adoption-chart" class="chart"></div>
  <aside class="notes">
    Percentage of active devs per week with at least one AI-tagged commit. The shape of the curve matters more than any single point.
  </aside>
</section>

{{ if .StatsAvailable }}
<section>
  <h2>Distribution</h2>
  <table class="stats-table">
    <thead>
      <tr>
        <th>Per ISO week</th>
        <th>median</th>
        <th>p10</th>
        <th>p90</th>
        <th>min</th>
        <th>max</th>
        <th>mean</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Commits</td>
        <td>{{ printf "%.1f" .StatsCommits.Median }}</td>
        <td>{{ printf "%.1f" .StatsCommits.P10 }}</td>
        <td>{{ printf "%.1f" .StatsCommits.P90 }}</td>
        <td>{{ printf "%.0f" .StatsCommits.Min }}</td>
        <td>{{ printf "%.0f" .StatsCommits.Max }}</td>
        <td>{{ printf "%.1f" .StatsCommits.Mean }}</td>
      </tr>
      <tr>
        <td>AI commits</td>
        <td>{{ printf "%.1f" .StatsAICommits.Median }}</td>
        <td>{{ printf "%.1f" .StatsAICommits.P10 }}</td>
        <td>{{ printf "%.1f" .StatsAICommits.P90 }}</td>
        <td>{{ printf "%.0f" .StatsAICommits.Min }}</td>
        <td>{{ printf "%.0f" .StatsAICommits.Max }}</td>
        <td>{{ printf "%.1f" .StatsAICommits.Mean }}</td>
      </tr>
      <tr>
        <td>AI ratio</td>
        <td class="accent">{{ printf "%.1f%%" .StatsRatioPct.Median }}</td>
        <td>{{ printf "%.1f%%" .StatsRatioPct.P10 }}</td>
        <td>{{ printf "%.1f%%" .StatsRatioPct.P90 }}</td>
        <td>{{ printf "%.1f%%" .StatsRatioPct.Min }}</td>
        <td>{{ printf "%.1f%%" .StatsRatioPct.Max }}</td>
        <td>{{ printf "%.1f%%" .StatsRatioPct.Mean }}</td>
      </tr>
    </tbody>
  </table>
  {{ if .StatsTrendKnown }}
  <p class="stats-trend">Trend (AI ratio): <span class="accent">{{ printf "%+.1f pp/week" .StatsTrendSlope }}</span> ({{ .StatsTrendDirection }})</p>
  {{ end }}
  {{ if .StatsCutoverAvailable }}
  <div class="stats-cohort-grid">
    <div>
      <h4>Before cutover</h4>
      <p>{{ .StatsBeforeWeeks }} weeks</p>
      <p>commits mean <span class="accent">{{ printf "%.1f" .StatsBeforeCommits }}</span></p>
      <p>AI ratio mean <span class="accent">{{ printf "%.1f%%" .StatsBeforeRatioPct }}</span></p>
    </div>
    <div>
      <h4>After cutover</h4>
      <p>{{ .StatsAfterWeeks }} weeks</p>
      <p>commits mean <span class="accent">{{ printf "%.1f" .StatsAfterCommits }}</span></p>
      <p>AI ratio mean <span class="accent">{{ printf "%.1f%%" .StatsAfterRatioPct }}</span></p>
    </div>
  </div>
  {{ end }}
  {{ if .ToolsAvailable }}
  <div class="stats-tools">
    <h4>AI tools detected ({{ .ToolsCommitsTotal }} commit{{ if ne .ToolsCommitsTotal 1 }}s{{ end }})</h4>
    <table class="stats-table stats-tools-table">
      <thead>
        <tr>
          <th>Tool</th>
          <th>Commits</th>
          <th>Share</th>
        </tr>
      </thead>
      <tbody>
        {{ range .Tools }}
        <tr>
          <td>{{ .Source }}</td>
          <td>{{ .Commits }}</td>
          <td class="accent">{{ printf "%.1f%%" .Pct }}</td>
        </tr>
        {{ end }}
      </tbody>
    </table>
  </div>
  {{ end }}
  <aside class="notes">
    Distribution of weekly commit and AI-commit counts. p10 / p90 bracket the typical range, so a wide spread between them is more interesting than the mean. The cutover split compares the cohort means before vs. after the auto-detected adoption week. AI tools detected: per-tool share of attributed commits (a commit with signals from multiple tools counts under each).
  </aside>
</section>
{{ end }}

{{ if .CyclesAvailable }}
<section data-chart="cycle">
  <h2>Cycle time</h2>
  <div id="cycle-chart" class="chart"></div>
  <p class="footnote">
    {{ .CycleTickets }} tickets with cycle data — median Idea → Dev <span class="accent">{{ .MedianIdeaToDevText }}</span>, median Dev → Release <span class="accent">{{ .MedianDevToRelText }}</span>.
    {{ printf "%.0f%%" .CycleFallbackPct }} of tickets used first-commit fallback (no matching tracker transition).
  </p>
  <aside class="notes">
    Idea → Dev is ticket created → first tracker transition into a "dev started" status (or first commit, when no matching transition exists). Dev → Release is that moment → last commit on the ticket.
  </aside>
</section>
{{ end }}

<section>
  <h2>Methodology</h2>
  <div class="caveats">
    <h4>High-confidence (direct evidence)</h4>
    <ul>
      <li><code>Co-Authored-By</code> trailer (Claude, Aider, Copilot, Cursor, Devin, Gemini Code Assist, Jules, OpenCode)</li>
      <li>Body footer (<code>Generated with [Claude Code]</code>, <code>Generated with [opencode]</code>)</li>
      <li>Author identity is a known AI bot (Copilot Coding Agent, Devin, Gemini Code Assist, Jules)</li>
      <li>PR carries an AI label or originates from an AI branch prefix (<code>copilot/</code>, <code>cursor/</code>, …)</li>
      <li>Squash-merge recovery — trailers on pre-squash PR commits attributed to the merge SHA</li>
    </ul>
    <h4>Medium-confidence (inferred)</h4>
    <ul>
      <li>Seat-holder propagation — untagged commits from a developer who has direct AI evidence in the same week and repo</li>
      <li>Unrecognised <code>*[bot]</code> author identity — likely automated, tool unknown</li>
    </ul>
    <p><b>Cutover:</b> {{ .CutoverText }}</p>
  </div>
  <aside class="notes">
    Confidence levels feed the chart. The throughput stack splits into "AI (evidence)" and "AI (inferred)" whenever any week has medium-confidence commits.
  </aside>
</section>

<section>
  <h2>Caveats</h2>
  <div class="caveats">
    <h4>Not in this report yet</h4>
    <ul>
      <li>Cycle time (needs Jira tickets + Bitbucket PRs)</li>
      <li>Defect rate / quality counterweight</li>
      <li>Per-team breakdown</li>
    </ul>
    <p>Cutover threshold: a week qualifies when AI-tagged commits reach <span class="accent">{{ printf "%.0f%%" .CutoverThresholdPct }}</span> of weekly commits.</p>
    <p class="muted">ROI is intentionally omitted — the assumption it requires (hours saved per AI-tagged commit) can't be defended in front of a skeptical CFO.</p>
  </div>
  <aside class="notes">
    The honest-measurement pitch. Skeptic-friendly slide.
  </aside>
</section>

</div>
</div>
<script src="assets/reveal.js"></script>
<script src="assets/echarts.min.js"></script>
<script>
  // ECharts option payloads built by internal/deck/charts.go and embedded
  // verbatim via template.JS — JSON object literals are valid JS.
  const throughputOption = {{ .Charts.ThroughputJSON }};
  const adoptionOption = {{ .Charts.AdoptionJSON }};
  {{ if .Charts.HasCycle }}const cycleOption = {{ .Charts.CycleJSON }};{{ end }}

  // Cutover indices come alongside the option payloads. The cutover
  // marker is drawn as a `graphic` overlay (see overlayCutover below)
  // because ECharts markLine on a category axis snaps to integer
  // indices, which forces the line through a bar centre.
  const chartOptions = {
    throughput: throughputOption,
    adoption: adoptionOption,
    {{ if .Charts.HasCycle }}cycle: cycleOption,{{ end }}
  };
  const cutoverIdx = {
    throughput: {{ .Charts.ThroughputCutoverIdx }},
    adoption: {{ .Charts.AdoptionCutoverIdx }},
    {{ if .Charts.HasCycle }}cycle: {{ .Charts.CycleCutoverIdx }},{{ end }}
  };
  const chartInstances = {};

  // overlayCutover draws a red dashed vertical line at the LEFT
  // boundary of the cutover bar's slot — bar `idx` is the first
  // AI-adoption week (per analyze.DetectCutover) and belongs on the
  // "post-AI" side of the line. Positions are computed in pixels via
  // convertToPixel so the line lands at the slot boundary regardless
  // of week count or reveal's slide scale.
  //   idx >= 1 → midpoint between bars (idx-1) and idx
  //   idx == 0 → left edge of bar 0's slot, sampled via bar 1
  function overlayCutover(instance, idx) {
    if (idx == null || idx < 0) {
      instance.setOption({ graphic: { elements: [{ $action: 'remove', id: 'cutover' }] } });
      return;
    }
    const pxC = instance.convertToPixel({ xAxisIndex: 0 }, idx);
    const pxNeighbour = instance.convertToPixel({ xAxisIndex: 0 }, idx === 0 ? 1 : idx - 1);
    if (!isFinite(pxC) || !isFinite(pxNeighbour)) return;
    const slotHalf = Math.abs(pxC - pxNeighbour) / 2;
    const x = pxC - slotHalf;

    // Plot vertical bounds: from the y-axis maximum (top) to minimum (bottom).
    const yExtent = instance.getModel().getComponent('yAxis', 0).axis.scale.getExtent();
    const yTop = instance.convertToPixel({ yAxisIndex: 0 }, yExtent[1]);
    const yBot = instance.convertToPixel({ yAxisIndex: 0 }, yExtent[0]);

    // When the line sits at the plot's left edge (idx == 0), a centred
    // pill would clip past the chart; nudge it to the right of the
    // line so it points INTO the plot instead of straddling the edge.
    const atLeftEdge = idx === 0;
    const pillX = atLeftEdge ? x + 4 : x - 60;
    const textX = atLeftEdge ? x + 64 : x;

    instance.setOption({
      graphic: {
        elements: [{
          id: 'cutover',
          type: 'group',
          silent: true,
          z: 100,
          children: [
            {
              type: 'line',
              shape: { x1: x, y1: yTop, x2: x, y2: yBot },
              style: { stroke: '#ef4444', lineWidth: 3, lineDash: [8, 6] }
            },
            {
              type: 'rect',
              shape: { x: pillX, y: yTop - 12, width: 120, height: 22 },
              style: { fill: '#ef4444' }
            },
            {
              type: 'text',
              style: {
                text: '▼ AI cutover',
                fill: '#ffffff',
                fontWeight: 'bold',
                fontSize: 13,
                x: textX,
                y: yTop - 1,
                textAlign: 'center',
                textVerticalAlign: 'middle'
              }
            }
          ]
        }]
      }
    });
  }

  // Reveal hides non-current slides with display:none. Initialising an
  // ECharts instance on a hidden container locks it to 0×0 and resize()
  // doesn't always recover; instead lazy-init each chart the first time
  // its slide becomes visible. <section data-chart="..."> is the
  // discriminator so the script doesn't hard-code chart IDs.
  function showChartFor(slide) {
    if (!slide) return;
    const kind = slide.dataset && slide.dataset.chart;
    if (!kind || !chartOptions[kind]) return;
    const div = slide.querySelector('.chart');
    if (!div) return;
    let instance = chartInstances[kind];
    if (!instance) {
      instance = echarts.init(div, null, { renderer: 'canvas' });
      instance.setOption(chartOptions[kind]);
      chartInstances[kind] = instance;
    }
    instance.resize();
    overlayCutover(instance, cutoverIdx[kind]);
  }

  Reveal.initialize({
    hash: true,
    controls: true,
    progress: true,
    slideNumber: 'c/t',
    transition: 'fade',
    backgroundTransition: 'none'
  }).then(function () {
    Reveal.on('slidechanged', function (e) { showChartFor(e.currentSlide); });
    // Handle the case where the deck loads directly on a chart slide
    // (e.g. via #/3) — the slidechanged event won't fire for the initial slide.
    showChartFor(Reveal.getCurrentSlide());
    window.addEventListener('resize', function () {
      for (const k in chartInstances) {
        chartInstances[k].resize();
        overlayCutover(chartInstances[k], cutoverIdx[k]);
      }
    });
  });
</script>

<script>
  // ---------------------------------------------------------------------
  // Background effect: 3-layer parallax starfield, gray-only. Runs
  // independently of reveal.js and ECharts. Honours
  // prefers-reduced-motion (canvas stays empty, fallback bg shows).
  // ---------------------------------------------------------------------
  (function () {
    const cvs = document.getElementById('bg-fx');
    if (!cvs || typeof cvs.getContext !== 'function') return;
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const ctx = cvs.getContext('2d');
    const dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
    let W = 0, H = 0;
    const stars = [];

    function resize() {
      W = cvs.width = Math.floor(window.innerWidth * dpr);
      H = cvs.height = Math.floor(window.innerHeight * dpr);
      cvs.style.width = window.innerWidth + 'px';
      cvs.style.height = window.innerHeight + 'px';
    }
    window.addEventListener('resize', resize, { passive: true });
    resize();

    // Stars: 3 parallax layers, all gray-toned. Back layer is dim and
    // slow; front layer is bigger, brighter, and faster. Each star wraps
    // around when it crosses the left edge.
    function seedStars() {
      stars.length = 0;
      const layers = [
        { count: 110, speed: 0.35, size: 1.0, alpha: 0.30, color: '107, 114, 128' },  // dim gray
        { count: 70,  speed: 0.9,  size: 1.6, alpha: 0.55, color: '156, 163, 175' },  // muted gray
        { count: 30,  speed: 1.8,  size: 2.2, alpha: 0.80, color: '229, 231, 235' },  // bright gray
      ];
      for (const L of layers) {
        for (let i = 0; i < L.count; i++) {
          stars.push({
            x: Math.random() * W,
            y: Math.random() * H,
            vx: L.speed * dpr,
            size: L.size * dpr,
            alpha: L.alpha,
            color: L.color,
          });
        }
      }
    }
    seedStars();
    window.addEventListener('resize', seedStars, { passive: true });

    function frame() {
      // Solid bg matching --bg so stars over slides look intentional.
      ctx.fillStyle = '#0b0f17';
      ctx.fillRect(0, 0, W, H);

      for (let i = 0; i < stars.length; i++) {
        const s = stars[i];
        s.x -= s.vx;
        if (s.x < -s.size) {
          s.x = W + Math.random() * 30;
          s.y = Math.random() * H;
        }
        ctx.fillStyle = 'rgba(' + s.color + ', ' + s.alpha + ')';
        ctx.fillRect(s.x, s.y, s.size, s.size);
      }

      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  })();
</script>
</body>
</html>
